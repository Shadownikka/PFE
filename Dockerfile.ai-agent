# AI Agent Container - Isolated Ollama + Llama 3.2
FROM ollama/ollama:latest

# Install Python and dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy AI agent requirements
COPY requirements-agent.txt .
RUN pip3 install --no-cache-dir --break-system-packages -r requirements-agent.txt

# Copy AI agent code
COPY net_agent.py .
COPY tool.py .

# Expose Ollama API port
EXPOSE 11434

# Start Ollama service and keep container running
ENTRYPOINT ["/bin/bash", "-c", "ollama serve & sleep 10 && ollama pull llama3.2 && wait"]
